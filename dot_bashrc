# N-CompassTV navigation function with tab completion
ntv() {
    if [ $# -eq 0 ]; then
        cd ~/n-compasstv
        echo "📁 N-CompassTV root directory"
        ls -1 ~/n-compasstv/ | sed 's/^/  • /'
    else
        case "$1" in
            api|api-v1)
                cd ~/n-compasstv/api-v1 && echo "🔧 API v1 project"
                ;;
            api-wt|worktree|worktrees)
                cd ~/n-compasstv/api-v1-worktrees && echo "🌿 API v1 worktrees"
                ;;
            dash|dashboard)
                cd ~/n-compasstv/dashboard-v1 && echo "📊 Dashboard v1 project"
                ;;
            dash-wt)
                cd ~/n-compasstv/dashboard-v1-worktrees && echo "🌿 Dashboard v1 worktrees"
                ;;
            player|server)
                cd ~/n-compasstv/player-server && echo "🎥 Player server project"
                ;;
            player-wt)
                cd ~/n-compasstv/player-server-worktrees && echo "🌿 Player server worktrees"
                ;;
            ui|player-ui)
                cd ~/n-compasstv/player-ui && echo "🎨 Player UI project"
                ;;
            *)
                echo "❌ Unknown project: $1"
                echo "Available: api, dash, player, ui, worktrees"
                return 1
                ;;
        esac
    fi
}

# Tab completion for ntv function
_ntv_completion() {
    local cur prev
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    if [ ${COMP_CWORD} == 1 ]; then
        COMPREPLY=($(compgen -W "api api-wt dash dash-wt player player-wt ui" -- ${cur}))
    fi
}
complete -F _ntv_completion ntv

# Project status overview
ntv-status() {
    echo "🏗️  N-CompassTV Project Status"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    for project in api-v1 dashboard-v1 player-server player-ui; do
        if [ -d ~/n-compasstv/$project ]; then
            echo "📁 $project:"
            if [ -d ~/n-compasstv/$project/.git ]; then
                cd ~/n-compasstv/$project
                echo "  Branch: $(git branch --show-current 2>/dev/null || echo 'unknown')"
                echo "  Status: $(git status --porcelain 2>/dev/null | wc -l) changed files"
            else
                echo "  Status: Not a git repository"
            fi
        fi
    done
    cd ~/n-compasstv
}

