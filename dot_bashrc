# Fix for WSL/ConPTY mouse tracking getting stuck after TUI exit
alias fixmouse="printf '\e[?1000l\e[?1002l\e[?1003l\e[?1006l'"

# Note: The system-wide keyring has been masked at:
# ~/.local/share/dbus-1/services/org.freedesktop.secrets.service
# This prevents any app (like gemini-cli) from triggering the GUI popup.
export EDITOR=/usr/bin/nano

# opencode
export PATH=/home/pi/.opencode/bin:$PATH

# Deduplicate PATH to prevent performance issues
if [ -n "$PATH" ]; then
    old_PATH=$PATH:
    PATH=
    while [ -n "$old_PATH" ]; do
        x=${old_PATH%%:*}
        case $PATH: in
            *:"$x":*) ;;
            *) PATH=$PATH:$x;;
        esac
        old_PATH=${old_PATH#*:}
    done
    PATH=${PATH#:}
    unset old_PATH x
fi

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
