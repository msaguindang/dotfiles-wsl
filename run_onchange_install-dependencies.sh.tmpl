#!/usr/bin/env bash
set -euo pipefail
{{ if eq .chezmoi.os "linux" }}

# =============================================================================
# SYSTEM TOOLS
# =============================================================================

# Starship prompt
if ! command -v starship >/dev/null 2>&1; then
    echo "[deps] Installing starship..."
    curl -sS https://starship.rs/install.sh | sh -s -- --yes
fi

# eza (modern ls replacement) — via apt if available, else cargo
if ! command -v eza >/dev/null 2>&1; then
    echo "[deps] Installing eza..."
    if apt-cache show eza >/dev/null 2>&1; then
        sudo apt-get install -y eza
    elif command -v cargo >/dev/null 2>&1; then
        cargo install eza
    else
        echo "[deps] WARNING: eza not installed — no apt package and cargo missing"
    fi
fi

# btop (system monitor)
if ! command -v btop >/dev/null 2>&1; then
    echo "[deps] Installing btop..."
    sudo apt-get install -y btop
fi

# yazi (terminal file manager)
if ! command -v yazi >/dev/null 2>&1; then
    echo "[deps] Installing yazi..."
    if command -v cargo >/dev/null 2>&1; then
        cargo install --locked yazi-fm yazi-cli
    else
        echo "[deps] WARNING: yazi not installed — cargo missing"
    fi
fi

# fastfetch (system info)
if ! command -v fastfetch >/dev/null 2>&1; then
    echo "[deps] Installing fastfetch..."
    sudo apt-get install -y fastfetch
fi

# jq (JSON parser)
if ! command -v jq >/dev/null 2>&1; then
    echo "[deps] Installing jq..."
    sudo apt-get install -y jq
fi

# keychain (SSH agent management)
if ! command -v keychain >/dev/null 2>&1; then
    echo "[deps] Installing keychain..."
    sudo apt-get install -y keychain
fi

# =============================================================================
# RUNTIME: NVM + NODE
# =============================================================================
if [ ! -d "$HOME/.nvm" ]; then
    echo "[deps] Installing nvm..."
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash
    export NVM_DIR="$HOME/.nvm"
    # shellcheck source=/dev/null
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    echo "[deps] Installing Node LTS..."
    nvm install --lts
fi

# =============================================================================
# RUNTIME: .NET (SDK)
# =============================================================================
if ! command -v dotnet >/dev/null 2>&1; then
    echo "[deps] Installing .NET SDK..."
    sudo apt-get install -y dotnet-sdk-8.0 || \
        echo "[deps] WARNING: dotnet-sdk-8.0 not in apt — install manually from https://dot.net"
fi

{{ end }}
